# Server
PORT=4000
# Comma-separate multiple allowed origins if needed
CORS_ORIGIN=http://localhost:3000

# SMTP credentials (example uses a generic provider).
# Gmail: use an App Password. SendGrid: user "apikey" + your API key.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Where the form notification is sent, and the from address shown.
MAIL_TO=hello@menoxis.com
MAIL_FROM=Menoxis <hello@menoxis.com>
